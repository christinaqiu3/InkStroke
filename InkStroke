class INKSTROKE_OT_set_panel_depth(bpy.types.Operator):
    bl_idname = "inkstroke.set_panel_depth"
    bl_label = "Set Panel Depth"

    def invoke(self, context, event):
        context.window_manager.modal_handler_add(self)
        return {'RUNNING_MODAL'}

    def modal(self, context, event):
        global panel_origin, panel_normal, panel_depth, panel_object

        if event.type == 'LEFTMOUSE' and event.value == 'PRESS':

            region = context.region
            rv3d = context.region_data
            coord = (event.mouse_region_x, event.mouse_region_y)

            origin = view3d_utils.region_2d_to_origin_3d(region, rv3d, coord)
            direction = view3d_utils.region_2d_to_vector_3d(region, rv3d, coord)

            cam_loc = rv3d.view_matrix.inverted().translation

            # camera forward direction (normal of drawing plane)
            view_dir = rv3d.view_rotation @ Vector((0, 0, -1))
            panel_normal = view_dir.normalized()

            # -----------------------------
            # CASE 1: USE SELECTED OBJECT
            # -----------------------------
            if context.active_object:
                obj = context.active_object
                panel_object = obj
                panel_origin = obj.location

                panel_depth = (panel_origin - cam_loc).length

                self.report({'INFO'}, f"Panel set from selected object {obj.name}")
                return {'FINISHED'}

            # -----------------------------
            # CASE 2: RAYCAST
            # -----------------------------
            hit, location, normal, index, obj, matrix = context.scene.ray_cast(
                context.evaluated_depsgraph_get(),
                origin,
                direction
            )

            if hit:
                panel_origin = location
                panel_object = obj
                panel_depth = (location - cam_loc).length

                # highlight object
                bpy.ops.object.select_all(action='DESELECT')
                obj.select_set(True)
                context.view_layer.objects.active = obj

                # ensure outline is visible
                if context.space_data:
                    context.space_data.shading.show_object_outline = True

                self.report({'INFO'}, f"Panel set on {obj.name}")

            else:
                # -----------------------------
                # CASE 3: EMPTY SPACE
                # -----------------------------
                panel_depth = 5.0  # default distance
                panel_origin = cam_loc + direction * panel_depth
                panel_object = None

                bpy.ops.object.select_all(action='DESELECT')

                self.report({'INFO'}, "Panel set in empty space")

            return {'FINISHED'}

        elif event.type in {'RIGHTMOUSE', 'ESC'}:
            return {'CANCELLED'}

        return {'RUNNING_MODAL'}


# Settings

class InkStrokeSettings(bpy.types.PropertyGroup):
    use_projection: bpy.props.BoolProperty(
        name="Surface Projection",
        default=False
    )
    min_distance: bpy.props.FloatProperty(
        name="Point Spacing",
        description="Minimum distance between stroke points (higher = smoother)",
        default=0.15,
        min=0.001,
        max=1.0,
    )
    width: bpy.props.FloatProperty(
        name="Stroke Width",
        default=0.05,
        min=0.001,
        max=1.0,
        update=mark_dirty
    )
    width_falloff: bpy.props.FloatProperty(
        name="Taper",
        default=1.0,
        min=0.0,
        max=2.0,
        update=mark_dirty
    )
    panel_mode: bpy.props.BoolProperty(
        name="2D Panel Mode",
        default=False
    )

    panel_depth: bpy.props.FloatProperty(
        name="Panel Depth",
        default=5.0
    )

    recording_enabled: bpy.props.BoolProperty(
        name="Record Strokes",
        description="Record the order in which strokes are created",
        default=False
    )

    replay_frame: bpy.props.IntProperty(
        name="Replay Frame",
        description="Current point in playback animation (0 = all hidden, max = all visible)",
        default=0,
        min=0,
        max=10000
    )

# Material

def get_inkstroke_material():

    mat_name = "InkStroke_Material"

    # Reuse if already exists
    if mat_name in bpy.data.materials:
        return bpy.data.materials[mat_name]

    mat = bpy.data.materials.new(mat_name)
    mat.use_nodes = True

    nodes = mat.node_tree.nodes
    links = mat.node_tree.links

    nodes.clear()

    # Nodes
    output = nodes.new("ShaderNodeOutputMaterial")
    principled = nodes.new("ShaderNodeBsdfPrincipled")
    texcoord = nodes.new("ShaderNodeTexCoord")
    separate = nodes.new("ShaderNodeSeparateXYZ")
    noise = nodes.new("ShaderNodeTexNoise")
    colramp = nodes.new("ShaderNodeValToRGB")

    # Layout for cleanliness
    texcoord.location = (-800, 0)
    separate.location = (-600, 0)
    noise.location = (-400, 0)
    colramp.location = (-200, 0)
    principled.location = (0, 0)
    output.location = (200, 0)

    # Settings
    noise.inputs["Scale"].default_value = 20
    noise.inputs["Roughness"].default_value = 0.6

    colramp.color_ramp.elements[0].position = 0.3
    colramp.color_ramp.elements[1].position = 0.7

    principled.inputs["Base Color"].default_value = (0.02, 0.02, 0.02, 1)

    # Links
    links.new(texcoord.outputs["UV"], separate.inputs["Vector"])
    links.new(separate.outputs["X"], noise.inputs["Vector"])
    links.new(noise.outputs["Fac"], colramp.inputs["Fac"])
    links.new(colramp.outputs["Color"], principled.inputs["Base Color"])
    links.new(principled.outputs["BSDF"], output.inputs["Surface"])

    return mat



# global update handler
def inkstroke_live_update(scene):
    for obj in scene.objects:
        if obj.type == 'MESH' and "inkstroke_source" in obj:
            source_name = obj["inkstroke_source"]
            source = scene.objects.get(source_name)
            

            if not source:
                continue

            if not source.get("inkstroke_dirty"):
                continue

            regenerate_mesh_from_curve(source, obj)
            source["inkstroke_dirty"] = False


