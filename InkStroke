# changed stroke
def mark_dirty(self, context):
    obj = context.active_object
    if obj:
        obj["inkstroke_dirty"] = True

# -----------------------------
# RAY → PLANE INTERSECTION
# -----------------------------
def intersect_ray_plane(ray_origin, ray_dir, plane_point, plane_normal):
    denom = plane_normal.dot(ray_dir)
    if abs(denom) < 1e-6:
        return None

    t = (plane_point - ray_origin).dot(plane_normal) / denom
    return ray_origin + ray_dir * t


import gpu
from gpu_extras.batch import batch_for_shader
import math

def draw_radius_gizmo():
    tool = active_radius_tool
    if not tool or not tool.active_point:
        return
 
    region = bpy.context.region
    rv3d = bpy.context.region_data
 
    # Project the 3D control point to screen space
    obj = tool.obj
    world_co = obj.matrix_world @ tool.active_point.co
    co_2d = view3d_utils.location_3d_to_region_2d(region, rv3d, world_co)
    if not co_2d:
        return
 
    # Radius circle sized by the radius change in screen pixels
    delta_r = tool.active_point.radius - tool.start_radius
    radius_px = max(20, abs(delta_r) / 0.003)
 
    segments = 48
    verts = []
    for i in range(segments):
        angle = (i / segments) * 2 * math.pi
        verts.append((co_2d.x + math.cos(angle) * radius_px,
                       co_2d.y + math.sin(angle) * radius_px))
 
    shader = gpu.shader.from_builtin('2D_UNIFORM_COLOR')
    gpu.state.blend_set('ALPHA')
 
    # Draw the circle
    batch = batch_for_shader(shader, 'LINE_LOOP', {"pos": verts})
    shader.bind()
    shader.uniform_float("color", (1.0, 0.75, 0.15, 0.9))
    batch.draw(shader)
 
    # Draw line from point to cursor
    if tool.drag_mouse_pos:
        line_verts = [tuple(co_2d), tool.drag_mouse_pos]
        line_batch = batch_for_shader(shader, 'LINES', {"pos": line_verts})
        shader.bind()
        shader.uniform_float("color", (1.0, 0.75, 0.15, 0.4))
        line_batch.draw(shader)
 
    # Draw numeric labels next to cursor
    if tool.drag_mouse_pos:
        font_id = 0
        mx, my = tool.drag_mouse_pos
        r_val = tool.active_point.radius
        scale = r_val / tool.start_radius if tool.start_radius > 0.001 else 1.0
 
        blf.size(font_id, 18)
        blf.color(font_id, 1.0, 0.85, 0.3, 1.0)
        blf.position(font_id, mx + 14, my + 8, 0)
        blf.draw(font_id, f"r = {r_val:.3f}")

        blf.size(font_id, 16)
        blf.color(font_id, 0.8, 0.8, 0.8, 0.85)
        blf.position(font_id, mx + 14, my - 8, 0)
        blf.draw(font_id, f"scale: {scale:.2f}x")

