def get_draw_point(context, coord):
    global panel_origin, panel_normal

    if panel_origin is None or panel_normal is None:
        return None

    region = context.region
    rv3d = context.region_data

    origin = view3d_utils.region_2d_to_origin_3d(region, rv3d, coord)
    direction = view3d_utils.region_2d_to_vector_3d(region, rv3d, coord)

    return intersect_ray_plane(origin, direction, panel_origin, panel_normal)

