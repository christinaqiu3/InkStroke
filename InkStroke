    INKSTROKE_PT_panel,
    INKSTROKE_OT_radius_tool,
    INKSTROKE_OT_set_panel_depth
)

def register():
    for cls in classes:
        bpy.utils.register_class(cls)
    bpy.types.Scene.inkstroke_settings = bpy.props.PointerProperty(
        type=InkStrokeSettings
    )

    settings = bpy.context.scene.inkstroke_settings
    
    if inkstroke_live_update not in bpy.app.handlers.depsgraph_update_post:
        bpy.app.handlers.depsgraph_update_post.append(inkstroke_live_update)

def unregister():
    del bpy.types.Scene.inkstroke_settings
    for cls in reversed(classes):
        bpy.utils.unregister_class(cls)

if __name__ == "__main__":
    register()
